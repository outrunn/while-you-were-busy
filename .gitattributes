# ===========================
# Unity .gitattributes
# Ensures consistent line endings and binary handling across platforms
# ===========================

# Auto detect text files and perform LF normalization
* text=auto

# ===========================
# Unity YAML files - must be text (mergeable)
# ===========================
*.cs        text eol=lf diff=csharp
*.shader    text eol=lf
*.compute   text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.glsl      text eol=lf
*.uss       text eol=lf
*.uxml      text eol=lf
*.asmdef    text eol=lf
*.asmref    text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf

# Unity serialized files — keep as text (YAML) for mergeability
*.unity     text eol=lf merge=unityyamlmerge
*.prefab    text eol=lf merge=unityyamlmerge
*.asset     text eol=lf merge=unityyamlmerge
*.meta      text eol=lf merge=unityyamlmerge
*.mat       text eol=lf merge=unityyamlmerge
*.anim      text eol=lf merge=unityyamlmerge
*.controller text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf merge=unityyamlmerge
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.playable  text eol=lf merge=unityyamlmerge
*.signal    text eol=lf
*.brush     text eol=lf
*.flare     text eol=lf
*.fontsettings text eol=lf
*.guiskin   text eol=lf
*.inputactions text eol=lf
*.mask      text eol=lf
*.mixer     text eol=lf
*.renderTexture text eol=lf
*.spriteatlas text eol=lf
*.terrainlayer text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf

# ===========================
# Binary files — no diffing or merging
# ===========================

# Images
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.bmp       binary
*.tga       binary
*.tiff      binary
*.psd       binary
*.exr       binary
*.hdr       binary
*.webp      binary

# Audio
*.mp3       binary
*.ogg       binary
*.wav       binary
*.aiff      binary
*.aif       binary
*.flac      binary

# Video
*.mp4       binary
*.mov       binary
*.avi       binary
*.webm      binary

# 3D Models
*.fbx       binary
*.obj       binary
*.blend     binary
*.dae       binary
*.3ds       binary
*.dxf       binary

# Fonts
*.ttf       binary
*.otf       binary
*.fon       binary

# Libraries and Plugins
*.dll       binary
*.pdb       binary
*.mdb       binary
*.so        binary
*.dylib     binary
*.a         binary

# Unity compiled assets
*.unity3d   binary
*.unitypackage binary
*.bundle    binary

# ===========================
# Git LFS — track large binary files
# ===========================
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.bmp filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.aiff filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.so filter=lfs diff=lfs merge=lfs -text
*.dylib filter=lfs diff=lfs merge=lfs -text
